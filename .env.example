# Copia este archivo como .env y coloca tu clave de la API de Anthropic
# Obtén una clave en https://platform.claude.com/
ANTHROPIC_API_KEY=sk-ant-...

# Clave de administrador: protege los expedientes clínicos y la lista de citas.
# Cámbiala por una clave propia y compártela solo con tu personal.
ADMIN_CLAVE=escribe-aqui-tu-clave

# Puerto del servidor (opcional)
PORT=3000
